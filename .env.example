# Copy this file to .env.local and fill in the values.
# The values below are safe non-secret defaults for local development.

# PostgreSQL connection string. Matches docker-compose.yml defaults.
DATABASE_URL=postgresql://hymnplay:hymnplay@localhost:5432/hymnplay

# Auth.js (NextAuth v5) secret. Generate one for local dev with:
#   openssl rand -base64 32
AUTH_SECRET=please-replace-me-with-a-32-char-random-string

# Public URL of the running app. For local dev this is http://localhost:3000.
AUTH_URL=http://localhost:3000

# Postgres credentials used by docker-compose.
# These match the DATABASE_URL above; change all four together if you change one.
POSTGRES_USER=hymnplay
POSTGRES_PASSWORD=hymnplay
POSTGRES_DB=hymnplay
